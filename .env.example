# ==============================================================================
# FRIDAY OS - Environment Variables Template
# ==============================================================================
# Copy this file to '.env' and populate with your own keys/credentials.
# DO NOT commit your actual '.env' file containing secrets to public repositories!

# 1. Gemini API Key (Required for online LLM mode)
# Get your API key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Local Express Server Configuration
PORT=3000

# 3. Google Workspace OAuth 2.0 Credentials (Required for Gmail & Calendar Integration)
# Create OAuth 2.0 credentials in the Google Cloud Console: https://console.cloud.google.com/
# Set application type to 'Web Application'
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth-callback

# 4. Google Sheets Database Logs Configuration (Required for Sheets logging tool)
# Create a blank Google Sheet in your account and copy its spreadsheet ID from the URL:
# https://docs.google.com/spreadsheets/d/[SPREADSHEET_ID_HERE]/edit
SPREADSHEET_ID=your_google_sheets_spreadsheet_id_here
